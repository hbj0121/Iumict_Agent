gitignore
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
# PyCharm
.idea/
*.iml
*.iws
# 환경변수
.env
*.env
!.env.example
# 데이터베이스
*.db
*.sqlite3
# 모델 파일 (용량 큰 파일)
models/*.pth
models/*.h5
models/*.pkl
!models/.gitkeep
# 업로드 파일
uploads/*
!uploads/.gitkeep
# 로그
logs/
*.log
# OS
.DS_Store
Thumbs.db
# Docker
*.tar

# 실행방법
# FastAPI : src/application/api/main.py 실행
# Streamlit : Pycharm 터미널 : $env:PYTHONPATH="$PWD"; poetry run streamlit run src/application/ui/app.py
# 테스트 : poetry run pytest